<winuiex:WindowEx
    x:Class="TopToolbar.ToolbarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:TopToolbar"
    xmlns:winuiex="using:WinUIEx"
    xmlns:ttcontrols="using:TopToolbar.Controls"
    xmlns:viewModels="using:TopToolbar.ViewModels">
    <Grid
        x:Name="RootGrid"
        KeyDown="OnRootKeyDown"
        IsTabStop="True"
        Background="Transparent"
        Padding="{x:Bind local:ToolbarMetrics.ToolbarShadowPadding}"
        UseLayoutRounding="True">
        <Grid.Resources>
            <RadialGradientBrush
                x:Key="ToolbarBackgroundBrush"
                Center="0.5,1.02"
                GradientOrigin="0.5,1.02"
                RadiusX="0.95"
                RadiusY="1.25">
                <GradientStop Color="#EAFCF7F1" Offset="0" />
                <GradientStop Color="#DDEEE6DB" Offset="0.58" />
                <GradientStop Color="#CFD9CEC0" Offset="1" />
            </RadialGradientBrush>
            <SolidColorBrush x:Key="ToolbarBorderBrush" Color="#80FFFFFF" />
            <SolidColorBrush x:Key="ToolbarLabelBrush" Color="#FF2F3A3F" />
            <Color x:Key="ToolbarIconColor">#FF2F3A3F</Color>
            <SolidColorBrush x:Key="ToolbarIconBrush" Color="#FF2F3A3F" />
            <SolidColorBrush x:Key="ToolbarSeparatorBrush" Color="#2F2A3439" />
            <SolidColorBrush x:Key="ToolbarNotificationAccentBrush" Color="#FFD13438" />
            <SolidColorBrush x:Key="ButtonBackground" Color="#00000000" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#26000000" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#44000000" />
            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#14000000" />
            <FontFamily x:Key="ToolbarTextFontFamily">Segoe UI Variable Text</FontFamily>
            <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="52" />
                <Setter Property="Height" Value="52" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid">
                                <Border
                                    x:Name="BackgroundElement"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                    <ContentPresenter
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Padding="{TemplateBinding Padding}"
                                        Content="{TemplateBinding Content}" />
                                </Border>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames
                                                    Storyboard.TargetName="BackgroundElement"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame
                                                        KeyTime="0"
                                                        Value="{ThemeResource ButtonBackgroundPointerOver}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames
                                                    Storyboard.TargetName="BackgroundElement"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame
                                                        KeyTime="0"
                                                        Value="{ThemeResource ButtonBackgroundPressed}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames
                                                    Storyboard.TargetName="BackgroundElement"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame
                                                        KeyTime="0"
                                                        Value="{ThemeResource ButtonBackgroundDisabled}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="BackgroundElement"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0.75"
                                                    Duration="0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Border
            x:Name="ToolbarContainer"
            Loaded="ToolbarContainer_Loaded"
            MinHeight="{x:Bind local:ToolbarMetrics.ToolbarHeight}"
            Padding="{x:Bind local:ToolbarMetrics.ToolbarChromePadding}"
            CornerRadius="{x:Bind local:ToolbarMetrics.ToolbarCornerRadius}"
            Background="{ThemeResource ToolbarBackgroundBrush}"
            BorderBrush="{ThemeResource ToolbarBorderBrush}"
            BorderThickness="1"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            UseLayoutRounding="True"
            IsHitTestVisible="True">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid
                x:Name="MainStack"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ScrollViewer
                    Grid.Column="0"
                    x:Name="ToolbarScrollViewer"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollMode="Disabled">
                    <ItemsRepeater ItemsSource="{x:Bind ItemsViewModel.VisibleGroups, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <controls:StackLayout Orientation="Horizontal" Spacing="0" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ToolbarGroupViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border
                                        CornerRadius="15"
                                        Background="Transparent"
                                        Padding="4,2,4,2"
                                        Margin="2,0,2,0">
                                        <ItemsRepeater ItemsSource="{x:Bind Buttons, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <controls:StackLayout Orientation="Horizontal" Spacing="2" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="viewModels:ToolbarButtonItem">
                                                    <StackPanel
                                                        Orientation="Vertical"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Spacing="6"
                                                        Width="{x:Bind local:ToolbarMetrics.ButtonContainerWidth}"
                                                        Opacity="{x:Bind GroupOpacity, Mode=OneWay}"
                                                        Margin="2">
                                                        <Button
                                                            Style="{StaticResource ToolbarIconButtonStyle}"
                                                            IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                                                            Tag="{x:Bind}"
                                                            Click="OnToolbarButtonClick"
                                                            RightTapped="OnToolbarButtonRightTapped"
                                                            ToolTipService.ToolTip="{x:Bind Button.ToolTipText, Mode=OneWay}">
                                                            <Grid
                                                                Width="{x:Bind local:ToolbarMetrics.ToolbarButtonSize}"
                                                                Height="{x:Bind local:ToolbarMetrics.ToolbarButtonSize}">
                                                                <ttcontrols:ToolbarIconPresenter
                                                                    Button="{x:Bind Button}"
                                                                    IconSize="{x:Bind local:ToolbarMetrics.ToolbarIconFontSize}"
                                                                    Foreground="{ThemeResource ToolbarIconColor}"
                                                                    Opacity="{x:Bind IconOpacity, Mode=OneWay}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                                <ProgressRing
                                                                    Width="{x:Bind local:ToolbarMetrics.ProgressRingSize}"
                                                                    Height="{x:Bind local:ToolbarMetrics.ProgressRingSize}"
                                                                    Foreground="{ThemeResource ToolbarIconBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    IsActive="{x:Bind Button.IsExecuting, Mode=OneWay}"
                                                                    Visibility="{x:Bind ProgressVisibility, Mode=OneWay}" />
                                                            </Grid>
                                                        </Button>
                                                        <TextBlock
                                                            Text="{x:Bind Button.DisplayName, Mode=OneWay}"
                                                            FontSize="{x:Bind local:ToolbarMetrics.ToolbarLabelFontSize}"
                                                            FontFamily="{ThemeResource ToolbarTextFontFamily}"
                                                            Foreground="{ThemeResource ToolbarLabelBrush}"
                                                            HorizontalAlignment="Center"
                                                            TextAlignment="Center"
                                                            TextWrapping="NoWrap"
                                                            TextTrimming="CharacterEllipsis"
                                                            MaxWidth="{x:Bind local:ToolbarMetrics.ButtonLabelMaxWidth}"
                                                            Margin="0,4,0,0"
                                                            UseLayoutRounding="True" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Border>
                                    <Border
                                        Width="1"
                                        Height="{x:Bind local:ToolbarMetrics.ToolbarSeparatorHeight}"
                                        Background="{ThemeResource ToolbarSeparatorBrush}"
                                        VerticalAlignment="Center"
                                        Margin="8,0,8,0"
                                        IsHitTestVisible="False"
                                        CornerRadius="0.5"
                                        Visibility="{x:Bind TrailingSeparatorVisibility, Mode=OneWay}">
                                        <Border.Shadow>
                                            <ThemeShadow />
                                        </Border.Shadow>
                                        <Border.Translation>0,0,2</Border.Translation>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>

                <Border
                    Grid.Column="1"
                    x:Name="SettingsSeparator"
                    Width="1"
                    Height="{x:Bind local:ToolbarMetrics.ToolbarSeparatorHeight}"
                    Background="{ThemeResource ToolbarSeparatorBrush}"
                    VerticalAlignment="Center"
                    Margin="8,0,8,0"
                    IsHitTestVisible="False"
                    CornerRadius="0.5"
                    Visibility="{x:Bind ItemsViewModel.SettingsSeparatorVisibility, Mode=OneWay}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <Border.Translation>0,0,2</Border.Translation>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <StackPanel
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6"
                        Width="{x:Bind local:ToolbarMetrics.ButtonContainerWidth}"
                        Margin="2">
                        <Button
                            x:Name="SnapshotButton"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            Click="OnQuickSnapshotClick"
                            ToolTipService.ToolTip="Snapshot current desktop">
                            <FontIcon
                                Glyph="&#xE722;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="{x:Bind local:ToolbarMetrics.ToolbarIconFontSize}"
                                Foreground="{ThemeResource ToolbarIconBrush}" />
                        </Button>
                        <TextBlock
                            x:Name="SnapshotLabel"
                            Text="Snapshot"
                            FontSize="{x:Bind local:ToolbarMetrics.ToolbarLabelFontSize}"
                            FontFamily="{ThemeResource ToolbarTextFontFamily}"
                            Foreground="{ThemeResource ToolbarLabelBrush}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            TextWrapping="NoWrap"
                            TextTrimming="CharacterEllipsis"
                            MaxWidth="{x:Bind local:ToolbarMetrics.ButtonLabelMaxWidth}"
                            Margin="0,4,0,0"
                            UseLayoutRounding="True" />
                    </StackPanel>

                    <StackPanel
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6"
                        Width="{x:Bind local:ToolbarMetrics.ButtonContainerWidth}"
                        Margin="2">
                        <Button
                            x:Name="NewWorkspaceButton"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            IsEnabled="False"
                            Click="OnSnapshotClick"
                            ToolTipService.ToolTip="Create workspace from template">
                            <FontIcon
                                Glyph="&#xE710;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="{x:Bind local:ToolbarMetrics.ToolbarIconFontSize}"
                                Foreground="{ThemeResource ToolbarIconBrush}" />
                        </Button>
                        <TextBlock
                            x:Name="NewWorkspaceLabel"
                            Text="New Workspace"
                            FontSize="{x:Bind local:ToolbarMetrics.ToolbarLabelFontSize}"
                            FontFamily="{ThemeResource ToolbarTextFontFamily}"
                            Foreground="{ThemeResource ToolbarLabelBrush}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            TextWrapping="NoWrap"
                            TextTrimming="CharacterEllipsis"
                            MaxWidth="{x:Bind local:ToolbarMetrics.ButtonLabelMaxWidth}"
                            Margin="0,4,0,0"
                            UseLayoutRounding="True" />
                    </StackPanel>

                    <StackPanel
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6"
                        Width="{x:Bind local:ToolbarMetrics.ButtonContainerWidth}"
                        Margin="2">
                        <Button
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            Click="OnSettingsClick"
                            ToolTipService.ToolTip="Toolbar Settings">
                            <FontIcon
                                Glyph="&#xE713;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="{x:Bind local:ToolbarMetrics.ToolbarIconFontSize}"
                                Foreground="{ThemeResource ToolbarIconBrush}" />
                        </Button>
                        <TextBlock
                            Text="Settings"
                            FontSize="{x:Bind local:ToolbarMetrics.ToolbarLabelFontSize}"
                            FontFamily="{ThemeResource ToolbarTextFontFamily}"
                            Foreground="{ThemeResource ToolbarLabelBrush}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            TextWrapping="NoWrap"
                            TextTrimming="CharacterEllipsis"
                            MaxWidth="{x:Bind local:ToolbarMetrics.ButtonLabelMaxWidth}"
                            Margin="0,4,0,0"
                            UseLayoutRounding="True" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        <Canvas x:Name="RadialCanvas"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsHitTestVisible="True"
                MinWidth="280"
                MinHeight="280"/>
    </Grid>
</winuiex:WindowEx>
